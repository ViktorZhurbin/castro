{
	"name": "castro-monorepo",
	"version": "1.0.0",
	"private": true,
	"workspaces": [
		"core",
		"packages/*",
		"website",
		"test-site",
		"test-errors/*"
	],
	"scripts": {
		"dev": "bun --filter website dev",
		"build": "bun --filter website build",
		"format": "biome format --write",
		"check": "bun format && bun run --parallel --filter '!@test-errors/*' --if-present type-check build knip && bun test && bun run test:errors",
		"test:sites": "bun test ./test-site",
		"test:errors": "bun test test-errors",
		"test:errors:up": "UPDATE_SNAPSHOTS=1 bun test:errors",
		"loc": "bunx cloc core/src/ --exclude-dir=messages --not-match-f '.test'",
		"loc-files": "bun run loc --by-file"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"typescript": "^6.0.2"
	}
}
