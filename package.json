{
	"name": "castro-monorepo",
	"version": "1.0.0",
	"private": true,
	"workspaces": [
		"core",
		"packages/*",
		"website",
		"tests/**/*"
	],
	"scripts": {
		"dev": "bun --filter website dev",
		"build": "bun --filter website build",
		"format": "biome format --write && bun format:md",
		"format:md": "prettier --write '**/*.md'",
		"lint": "biome lint --write",
		"check": "bun format && bun lint && bun check:analyze && bun test && bun check:build",
		"check:analyze": "bun run --parallel --filter '*' --if-present type-check knip",
		"check:build": "bun run --parallel --filter '!@test-errors/*' --if-present build",
		"test:site": "bun test tests/site",
		"test:errors": "bun test tests/errors",
		"test:errors:up": "UPDATE_SNAPSHOTS=1 bun test:errors",
		"loc": "bunx cloc core/src/ --exclude-dir=messages --not-match-f '.test'",
		"loc:files": "bun run loc --by-file"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.1",
		"prettier": "3.9.0",
		"typescript": "^6.0.2"
	}
}
