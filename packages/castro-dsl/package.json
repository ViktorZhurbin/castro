{
	"name": "@vktrz/castro-dsl",
	"version": "0.1.0",
	"description": "Compiles .castro files into reactive createElement modules targeting castro-jsx.",
	"type": "module",
	"types": "./src/index.d.ts",
	"exports": {
		".": {
			"types": "./src/index.d.ts",
			"default": "./src/index.js"
		}
	},
	"files": [
		"src/"
	],
	"scripts": {
		"dev": "bun examples/serve.js",
		"type-check": "tsc"
	},
	"dependencies": {
		"node-html-parser": "^8.0.4"
	},
	"devDependencies": {
		"@happy-dom/global-registrator": "^20.10.6",
		"@vktrz/castro-jsx": "workspace:*",
		"@vktrz/signals": "workspace:*"
	}
}
